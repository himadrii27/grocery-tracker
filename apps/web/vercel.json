{
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm --filter @grocery-tracker/db generate && pnpm --filter @grocery-tracker/web build",
  "installCommand": "cd ../.. && ENABLE_EXPERIMENTAL_COREPACK=1 pnpm install",
  "outputDirectory": ".next",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- apps/web packages vercel.json"
}
