{
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @grocery-tracker/db generate && pnpm --filter @grocery-tracker/web build",
  "installCommand": "ENABLE_EXPERIMENTAL_COREPACK=1 pnpm install",
  "outputDirectory": "apps/web/.next",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- apps/web packages vercel.json"
}
